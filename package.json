{
  "name": "mini-crm",
  "version": "1.0.0",
  "description": "Mini CRM API with Node.js, Express, TypeScript, and PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "crm",
    "express",
    "typescript",
    "prisma"
  ],
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.30",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

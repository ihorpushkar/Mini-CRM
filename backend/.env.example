# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# Local dev with Railway public URL, or local Postgres:
# DATABASE_URL="postgresql://user:password@localhost:5432/mini_crm"
# Production on Railway: use ${{Postgres.DATABASE_URL}} reference (no angle brackets!)
DATABASE_URL="postgresql://user:password@localhost:5432/mini_crm"

# JWT — use a random secret, minimum 32 characters
JWT_SECRET=change-me-to-a-random-secret-key-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS — frontend origin (production: https://your-vercel-app.vercel.app)
CORS_ORIGIN=http://localhost:5173

# Server
PORT=3000

# Database (SQLite)
DATABASE_URL="file:./dev.db"

# JWT — use a random secret, minimum 32 characters
JWT_SECRET=change-me-to-a-random-secret-key-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS — frontend origin (production: https://your-domain.com)
CORS_ORIGIN=http://localhost:5173
